# Environment files
.env
.env.*

# Keep example
!.env.example

# Private data (keep the folder, ignore contents)
/data/private/*
!/data/private/.gitkeep

# Dump folder (keep the folder, ignore contents)
/data/dump_folder/*
!/data/dump_folder/.gitkeep

# Jupyter autosave/checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Notebook/runtime artifacts
.jupyter/
.jupyterlab/
.ipython/

# Python cache/artifacts often created while running notebooks
__pycache__/
*.py[cod]
*$py.class
.DS_Store
data/.DS_Store
jupyter_notebooks/data_cleaning_2.ipynb
jupyter_notebooks/data_cleaning_improved.ipynb
jupyter_notebooks/~$cleaned_data.xlsx

# Private data file
data_preprocessing/for_looking.txt