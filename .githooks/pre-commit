#!/bin/sh

run_python_hook() {
    cmd="$1"

    "$cmd" -c "import json" >/dev/null 2>&1 || return 127
    "$cmd" ".githooks/strip_notebooks.py"
    return $?
}

if command -v python3 >/dev/null 2>&1; then
    run_python_hook python3
    rc=$?
    if [ "$rc" -ne 127 ]; then
        exit "$rc"
    fi
fi

if command -v python >/dev/null 2>&1; then
    run_python_hook python
    rc=$?
    if [ "$rc" -ne 127 ]; then
        exit "$rc"
    fi
fi

if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -File ".githooks/pre-commit.ps1"
    exit $?
fi

if command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -ExecutionPolicy Bypass -File ".githooks/pre-commit.ps1"
    exit $?
fi

echo "pre-commit: no supported runtime found (python/powershell)." >&2
exit 1