#!/bin/sh

HOOK_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
STRIP_SCRIPT="$HOOK_DIR/strip_notebooks.py"

run_python_hook() {
    cmd="$1"

    "$cmd" -c "import json" >/dev/null 2>&1 || return 127
    "$cmd" "$STRIP_SCRIPT"
    return $?
}

if command -v python3 >/dev/null 2>&1; then
    run_python_hook python3
    rc=$?
    if [ "$rc" -ne 127 ]; then
        exit "$rc"
    fi
fi

if command -v python >/dev/null 2>&1; then
    run_python_hook python
    rc=$?
    if [ "$rc" -ne 127 ]; then
        exit "$rc"
    fi
fi

# Common absolute python3 locations on macOS when PATH is limited (e.g., GUI Git clients).
for py in /usr/bin/python3 /opt/homebrew/bin/python3 /usr/local/bin/python3; do
    if [ -x "$py" ]; then
        run_python_hook "$py"
        rc=$?
        if [ "$rc" -ne 127 ]; then
            exit "$rc"
        fi
    fi
done

if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -File "$HOOK_DIR/pre-commit.ps1"
    exit $?
fi

if command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -ExecutionPolicy Bypass -File "$HOOK_DIR/pre-commit.ps1"
    exit $?
fi

echo "pre-commit: no supported runtime found (python/powershell)." >&2
exit 1
